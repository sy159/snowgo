# ===== 部署环境变量 =====
# 复制此文件为 .env 并填入实际值，.env 不会被提交到版本控制
SERVICE_NAME=snowgo-service
ENV=container
SERVICE_IMAGE_NAME=snowgo
SERVICE_IMAGE_VERSION=1.0.0

# MySQL
MYSQL_ROOT_PASSWORD=zx.123
MYSQL_DATABASE=snowgo
MYSQL_PORT=3307

# Redis
REDIS_PORT=6380

# Nginx
NGINX_PORT=80

# Network
SUBNET=172.101.0.0/24

# ===== 部署环境变量 =====
# 复制此文件为 .env 并填入实际值，.env 不会被提交到版本控制
SERVICE_NAME=snowgo-service
ENV=container
SERVICE_IMAGE_NAME=snowgo
SERVICE_IMAGE_VERSION=1.0.0

# MySQL
MYSQL_ROOT_PASSWORD=zx.123
MYSQL_DATABASE=snowgo
MYSQL_PORT=3307

# Redis
REDIS_PORT=6380

# Nginx
NGINX_PORT=80

# Network
SUBNET=172.101.0.0/24

# ===== 应用敏感字段配置（UAT/PROD 部署时必填） =====
# 变量名需与 config/config.{uat,prod}.yaml 中的 ${VAR} 占位符一致

# 主库 DSN（必填）
#MYSQL_DSN=

# 读写分离 - 主库 DSN 列表（可选，用于读写分离）
# MYSQL_MAIN_DSN="root:pass@tcp(127.0.0.1:3306)/db1?charset=utf8mb4&parseTime=True&loc=Local"

# 读写分离 - 从库 DSN 列表（可选，用于读写分离）
# MYSQL_SLAVE_DSN_1="root:pass@tcp(127.0.0.1:3307)/db1?charset=utf8mb4&parseTime=True&loc=Local"
# MYSQL_SLAVE_DSN_2="root:pass@tcp(127.0.0.1:3308)/db1?charset=utf8mb4&parseTime=True&loc=Local"

# 用户库 DSN（可选，多数据源场景）
#MYSQL_USER_DSN=

# Redis 密码（可选）
#REDIS_PASSWORD=

# JWT 密钥（必填，生产环境请使用强随机字符串）
#JWT_SECRET=your-secret-key-change-in-production

# RabbitMQ 连接地址（可选）
#RABBITMQ_URL=amqp://guest:guest@127.0.0.1:5672/

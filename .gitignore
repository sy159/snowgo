# Env files (template .env.example is committed)
.env
!.env.example

# Runtime data directories
data/

!.gitkeep
*.log
/logs/
/config/*.prod.yaml

# IDE / Editor settings
.idea/
.vscode/
*.sublime*
*.iml

# OS system files
.DS_Store
Thumbs.db

# Editor swap / backup files
*~
*.swp
*.swo
*.bak

# Go build artifacts
*.exe
*.dll
*.so
*.dylib
*.test
*.out

# Docker runtime data
deploy/elk/*/data/
deploy/filebeat/*/data/
deploy/kibana/*/data/
deploy/monitor/grafana/
deploy/monitor/prometheus/data/
deploy/rabbitmq/data/

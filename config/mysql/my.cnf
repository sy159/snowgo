[mysqld]
# ===== 基础设置 =====
character-set-server = utf8mb4
collation-server = utf8mb4_unicode_ci
server_id = 1
default-time_zone = '+8:00'
# 兼容5.7及旧客户端；8.0.34+已弃用，未来需改用 authentication_policy
default-authentication-plugin = mysql_native_password

# 显式声明，避免版本升级导致行为变化
sql_mode = STRICT_TRANS_TABLES,NO_ZERO_IN_DATE,NO_ZERO_DATE,ERROR_FOR_DIVISION_BY_ZERO,NO_ENGINE_SUBSTITUTION

# 跳过DNS反查，加速连接建立
skip-name-resolve = ON

# ===== 二进制日志 =====
log_bin = ON
gtid_mode = ON
enforce_gtid_consistency = ON
# binlog保留7天自动清理
binlog_expire_logs_seconds = 604800

# ===== 慢查询日志 =====
slow_query_log = 1
slow_query_log_file = /var/log/mysql/slow.log
long_query_time = 2  # 超过2秒记录，生产建议1-2秒

# ===== 连接设置 =====
max_connections = 1500  # 建议500-2000，根据业务并发调整
max_connect_errors = 1000  # 超过后阻止新连接，FLUSH HOSTS可解除
back_log = 800  # 连接请求队列大小，队列满后拒绝新连接
open_files_limit = 65535  # 建议为 max_connections * 5
interactive_timeout = 1800  # 交互式连接空闲超时（如命令行），默认8h过长
wait_timeout = 1800  # 非交互式连接空闲超时（如应用连接），默认8h过长

# ===== 内存分配 =====
max_allowed_packet = 20M  # 单个数据包最大大小，有大字段时需调大
join_buffer_size = 1M  # JOIN无索引时的缓冲区，默认256KB
thread_cache_size = 32  # 线程缓存数，大量新连接时增大可减少创建线程开销
tmp_table_size = 128M  # 内存临时表最大大小，多GROUP BY时可调大
read_buffer_size = 1M  # 顺序读缓冲区，全表扫描多时可调大

# ===== 其他设置 =====
# 30秒超时自动终止（仅对SELECT生效），防慢SQL拖垮实例
max_execution_time = 30000

# ===== InnoDB 优化 =====
# 缓存表数据和索引的内存，建议物理内存的50%-70%
innodb_buffer_pool_size = 512M
# 8.0.30+引入innodb_redo_log_capacity替代此参数，两者不可同时设置
innodb_log_file_size = 256M
# 跳过OS页缓存直接写磁盘，避免双重缓冲
innodb_flush_method = O_DIRECT
innodb_purge_threads = 4

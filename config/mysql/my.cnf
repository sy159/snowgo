[mysqld]
# ===== 基础设置 =====
datadir = /var/lib/mysql  # 数据文件存储目录
pid-file = /var/run/mysqld/mysqld.pid  # 进程PID文件路径
socket = /var/run/mysqld/mysqld.sock  # 本地套接字文件，用于本地连接
character-set-server = utf8mb4  # 服务器默认字符集，utf8mb4支持4字节字符（如emoji）
collation-server = utf8mb4_unicode_ci  # 排序规则，unicode_ci支持多语言排序
server_id = 1  # 服务器唯一标识，主从复制时必须各不相同
default-time_zone = '+8:00'  # 服务器时区设为东八区
# MySQL 8.0 默认认证插件为 caching_sha2_password，设为 mysql_native_password 兼容5.7及旧客户端
# 5.7会忽略此参数，8.0会使用它创建新用户
default-authentication-plugin = mysql_native_password

# 显式声明 sql_mode，避免版本升级导致行为变化
# STRICT_TRANS_TABLES 严格模式，非法值直接报错而非警告
# NO_ZERO_IN_DATE 不允许日期中出现0值（如2024-00-01）
# NO_ZERO_DATE 不允许插入0000-00-00日期
# ERROR_FOR_DIVISION_BY_ZERO 除以零报错而非返回NULL
# NO_ENGINE_SUBSTITUTION 建表指定的引擎不存在时报错而非替换
sql_mode = STRICT_TRANS_TABLES,NO_ZERO_IN_DATE,NO_ZERO_DATE,ERROR_FOR_DIVISION_BY_ZERO,NO_ENGINE_SUBSTITUTION

# 跳过DNS反查，加速连接建立并避免DNS解析失败导致连接拒绝
skip_name_resolve = ON

# ===== 二进制日志 =====
# 主库必须开启sync-binlog，保证每次事务提交都刷盘，崩溃不丢失事务
sync-binlog = 1

# 开启binlog，用于主从复制和数据恢复
log_bin = ON
# binlog格式：row记录行变更，statement记录SQL语句，mixed混合模式。推荐row，数据一致性最好
binlog_format = row
# 开启GTID，简化主从切换和故障恢复
gtid_mode = ON
# 强制GTID一致性，禁止不安全的非事务性操作
enforce_gtid_consistency = ON
# binlog保留天数，过期自动清理（7天）
binlog_expire_logs_seconds = 604800
# 从库也将复制的事件写入自己的binlog，用于级联复制
log-slave-updates = ON

# ===== 慢查询日志 =====
slow_query_log = 1  # 开启慢查询日志
slow_query_log_file = /var/log/mysql/slow.log  # 慢查询日志文件路径
long_query_time = 2  # 超过2秒的查询记录下来

# ===== 连接设置 =====
# 一般设置为500-2000，根据业务并发量调整
max_connections = 1500  # 最大连接数
# 如果客户端尝试连接的错误数量超过这个值，服务器不再接受该客户端新连接。可通过FLUSH HOSTS解除阻止
max_connect_errors = 1000
# MySQL服务器连接请求队列所能处理的最大连接请求数，队列满后后续连接将被拒绝
back_log = 800
# 操作系统允许MySQL服务打开的文件数量。建议 max_connections * 5
open_files_limit = 65535
# 交互式连接空闲超时时间（如命令行客户端），过长会浪费连接资源
interactive_timeout = 1800  # 30分钟
# 非交互式连接空闲超时时间（如应用程序连接），过长会浪费连接资源且增加安全风险
wait_timeout = 1800  # 30分钟

# ===== 内存分配 =====
# 网络传输时单个数据包的最大大小。默认4MB，如果有大字段（TEXT/BLOB）需要调大
max_allowed_packet = 20M
# JOIN操作无索引时的缓冲区大小。默认256KB，多表关联无索引时可调大
join_buffer_size = 1M
# MySQL服务缓存以重用的线程数。客户端断开后线程放入缓存，新连接优先复用缓存线程，减少创建线程开销
# 默认值：8 + (max_connections / 100)，有大量新连接时可增大
thread_cache_size = 32
# 所有线程能同时打开的表缓存数量，与表数量和并发连接数相关
table_open_cache = 1024
# 内存中内部临时表的最大大小，超过则自动转为磁盘临时表。多GROUP BY/DISTINCT时可调大
tmp_table_size = 128M
# 顺序读缓冲区大小，全表扫描次数多时可调大
read_buffer_size = 1M

# ===== 其他设置 =====
# 防止单条慢SQL拖垮实例，30秒超时自动终止（仅对SELECT生效）
max_execution_time = 30000
# timestamp类型默认值行为：ON时TIMESTAMP列不会自动更新且不允许NULL默认值，8.0推荐开启
explicit_defaults_for_timestamp = ON

# ===== InnoDB 优化 =====
# InnDB缓存表数据和索引的内存大小。以InnoDB为主的系统，建议设为物理内存50%-70%
innodb_buffer_pool_size = 512M
# buffer_pool实例数。< 1G 时设1，达到1G+后建议设2-4，减少缓冲池争用
innodb_buffer_pool_instances = 1
# 事务日志文件大小，影响崩溃恢复时间和检查点频率。过小会导致频繁检查点
innodb_log_file_size = 256M
# 事务日志缓冲区大小，大事务可适当调大减少磁盘写入次数
innodb_log_buffer_size = 4M
# 事务提交时日志刷盘策略：0=每秒刷（可能丢1秒数据），1=每次提交刷（最安全），2=提交写入OS缓存每秒刷
# 主库保持1，保证事务不丢失
innodb_flush_log_at_trx_commit = 1
# InnoDB刷盘方式：O_DIRECT跳过OS页缓存直接写磁盘，避免双重缓冲减少内存浪费
innodb_flush_method = O_DIRECT
# 为每个InnoDB表分配独立的表空间（.ibd文件），便于单表回收磁盘空间
innodb_file_per_table = 1
# InnoDB后台写IO线程数，SSD可设4-8，HDD建议2-4
innodb_write_io_threads = 4
# InnoDB后台读IO线程数，SSD可设4-8，HDD建议2-4
innodb_read_io_threads = 4
# 清理无用数据的后台线程数
innodb_purge_threads = 4
